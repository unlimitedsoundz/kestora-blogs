<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Kestora Blog' %></title>
    <link href="/css/output.css?v=<%= Math.random() %>" rel="stylesheet">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body class="min-h-screen bg-white pt-16">
    <!-- Navigation Bar -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-neutral-200">
        <div class="container mx-auto px-4">
            <div class="flex items-center justify-between h-16">
                <!-- Logo -->
                <a href="https://kestora.online/" class="flex items-center space-x-2">
                    <img src="/images/logo-kestora.png" alt="Kestora University" class="h-8 w-auto" />
                    <span class="text-xl font-bold text-black">Kestora University</span>
                </a>

                <!-- Navigation Links -->
                <div class="hidden md:flex items-center space-x-8">
                    <a href="https://kestora.online/" class="text-neutral-600 hover:text-black transition-colors">Home</a>
                    <a href="https://kestora.online/about-kestora-university" class="text-neutral-600 hover:text-black transition-colors">About</a>
                    <a href="https://kestora.online/studies" class="text-neutral-600 hover:text-black transition-colors">Studies</a>
                    <a href="https://kestora.online/admissions" class="text-neutral-600 hover:text-black transition-colors">Admissions</a>
                    <a href="https://ourblogs.kestora.online" class="text-neutral-600 hover:text-black transition-colors font-medium">Blog</a>
                    <a href="https://kestora.online/contact" class="text-neutral-600 hover:text-black transition-colors">Contact</a>
                </div>

                <!-- Mobile Menu Button -->
                <button class="md:hidden text-neutral-600 hover:text-black">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                </button>
            </div>
        </div>
    </nav>
    <%- body %>

    <script>
        // Add any client-side JavaScript here
    </script>
</body>
</html>