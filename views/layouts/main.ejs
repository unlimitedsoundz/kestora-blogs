<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Kestora Blog' %></title>
    <link href="/css/output.css?v=<%= Math.random() %>" rel="stylesheet">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body class="min-h-screen bg-white">
    <!-- Inline CSS test -->
    <style>
        .css-test-inline { background: blue !important; color: white !important; padding: 10px !important; position: fixed !important; top: 50px !important; right: 10px !important; z-index: 9999 !important; }
    </style>

    <!-- CSS Test - These classes ensure Tailwind includes the utilities -->
    <div class="fixed top-2 right-2 bg-red-500 text-white p-2 text-xs z-50 rounded">
        Tailwind Test - If you see this styled, Tailwind is working!
    </div>
    <div class="css-test-inline">
        Inline CSS Test - If you see blue background, basic CSS works!
    </div>
    <!-- Hidden utility classes for Tailwind to include -->
    <div class="hidden bg-blue-500 text-red-500 text-green-600 font-bold text-lg text-white bg-black text-neutral-500 text-neutral-900 text-neutral-600 text-neutral-400 text-xs text-xl text-4xl text-5xl text-6xl text-sm max-w-xl leading-relaxed my-4 pt-8 pt-24 lg:pt-0 lg:w-1/2 w-full relative mt-4 lg:mt-0 lg:translate-y-16 z-20 z-10 flex flex-col lg:flex-row items-center gap-16 pt-32 pb-4 min-h-screen bg-white container mx-auto px-4 py-6 py-8 py-16 max-w-6xl max-w-4xl space-y-2 justify-center h-full object-cover opacity-90 shadow-2xl overflow-hidden rounded-xl bg-neutral-100 hover:bg-neutral-200 transition-colors h-full aspect-video bg-neutral-200 group-hover:scale-105 transition-transform duration-500 w-full mb-3 mb-4 p-6 flex-1 line-clamp-3 text-neutral-600 font-bold uppercase tracking-wider tracking-wide"></div>
    <%- body %>

    <script>
        // Add any client-side JavaScript here
    </script>
</body>
</html>