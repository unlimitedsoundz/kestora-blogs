    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Kestora Blog' %></title>
    <link href="/css/output.css?v=<%= Date.now() %>" rel="stylesheet">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body class="min-h-screen bg-white">
    <!-- CSS Test - These classes ensure Tailwind includes the utilities -->
    <div class="fixed top-2 right-2 bg-red-500 text-white p-2 text-xs z-50 rounded">
